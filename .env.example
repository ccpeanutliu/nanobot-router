# Copy to .env and adjust for local development

# Auth: "disabled" uses X-User-Id header directly (dev only)
ROUTER_AUTH_MODE=disabled

# Auth: JWT (production)
# ROUTER_AUTH_MODE=jwt
# ROUTER_JWT_JWKS_URL=https://your-sso.example.com/.well-known/jwks.json
# ROUTER_JWT_AUDIENCE=nanobot
# ROUTER_JWT_USER_ID_CLAIM=sub

# Auth: token introspection
# ROUTER_AUTH_MODE=introspection
# ROUTER_INTROSPECTION_URL=https://your-sso.example.com/oauth/introspect
# ROUTER_INTROSPECTION_USER_ID_FIELD=sub

# Paths
ROUTER_WORKSPACE_BASE=./workspaces
ROUTER_NANOBOT_CONFIG_PATH=~/.nanobot/config.json
ROUTER_NANOBOT_BIN=nanobot

# Port pool
ROUTER_PORT_RANGE_START=9000
ROUTER_PORT_RANGE_END=9010  # small range for local dev

# Lifecycle
ROUTER_IDLE_TIMEOUT_SECONDS=300
ROUTER_STARTUP_TIMEOUT_SECONDS=30
ROUTER_PROXY_TIMEOUT_SECONDS=120.0
